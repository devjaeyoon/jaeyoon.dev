---
import PostCard from "@/components/astro/PostCard.astro";
import type { PostCardData } from "@/lib/posts";

interface Props {
  posts: PostCardData[];
}

const { posts } = Astro.props;
---

<section class="pt-20">
  <h3 class="text-[32px] font-extrabold">최신 게시글</h3>
  <ul class="grid list-none grid-cols-1 gap-6 p-0 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => <PostCard post={post} />)}
  </ul>
</section>
